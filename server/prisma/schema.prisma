generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  admin
  member
  observer
}

enum BoardVisibility {
  workspace
  private
  public
}

enum ExportStatus {
  queued
  running
  completed
  failed
}

enum ActivityStatus {
  done
  seen
}

enum NotificationKind {
  direct
  watching
}

enum NotificationApp {
  trello
  jira
  confluence
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  emailVerified Boolean  @default(false)
  verifiedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceMembers WorkspaceMember[]
  activity         Activity[] @relation("ActivityActor")
  notifications    Notification[]
  exportJobs       ExportJob[]
  refreshTokens    RefreshToken[]
  emailVerificationCodes EmailVerificationCode[]
  passwordResetCodes PasswordResetCode[]
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String

  createdAt DateTime @default(now())
  expiresAt DateTime
  consumedAt DateTime?
  attempts  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String

  createdAt DateTime @default(now())
  expiresAt DateTime
  consumedAt DateTime?
  attempts  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique

  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  replacedByTokenId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members WorkspaceMember[]
  boards  Board[]
  activity Activity[]
  exportJobs ExportJob[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Board {
  id          String          @id @default(cuid())
  workspaceId String
  title       String
  description String?         @db.Text
  visibility  BoardVisibility @default(workspace)
  background  Json?
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists     List[]
  cards     Card[]
  activity  Activity[]
  notifications Notification[]

  @@index([workspaceId])
}

model List {
  id         String   @id @default(cuid())
  boardId    String
  title      String
  position   Int      @default(0)
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id          String   @id @default(cuid())
  boardId     String
  listId      String
  title       String
  description String?  @db.Text
  position    Int      @default(0)
  dueAt       DateTime?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list  List  @relation(fields: [listId], references: [id], onDelete: Cascade)

  attachments Attachment[]

  @@index([boardId])
  @@index([listId])
}

model Attachment {
  id        String   @id @default(cuid())
  cardId    String
  fileName  String
  mimeType  String?
  sizeBytes Int?
  url       String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  boardId     String?
  actorUserId String?
  message     String   @db.Text
  status      ActivityStatus @default(done)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board     Board?    @relation(fields: [boardId], references: [id], onDelete: SetNull)
  actor     User?     @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([boardId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  boardId   String?
  message   String   @db.Text
  kind      NotificationKind @default(direct)
  app       NotificationApp  @default(trello)
  createdAt DateTime @default(now())
  readAt    DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board? @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model ExportJob {
  id                  String       @id @default(cuid())
  workspaceId          String
  requestedByUserId    String
  status              ExportStatus @default(queued)
  includeAttachments   Boolean      @default(false)
  downloadUrl          String?
  createdAt            DateTime     @default(now())
  completedAt          DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy User @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([requestedByUserId, createdAt])
}
