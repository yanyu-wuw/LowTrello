# Server
PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-dev
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=lowtrello_rt

# Mail (local MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@lowtrello.local

# Email verification
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_CODE_RESEND_SECONDS=60
VERIFICATION_CODE_MAX_ATTEMPTS=5

# Legacy fallback (still supported)
# JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://lowtrello:lowtrello@localhost:5432/lowtrello?schema=public
